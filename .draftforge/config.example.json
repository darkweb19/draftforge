{
  "$schema": "./schema/config.schema.json",
  "roles": {
    "architect": {
      "adapter": "codex-cli",
      "model": "provider-default",
      "reasoning": "high"
    },
    "worker": {
      "adapter": "claude-cli",
      "model": "provider-default",
      "reasoning": "medium",
      "maxConcurrency": 2
    },
    "reviewer": {
      "adapter": "codex-cli",
      "model": "provider-default",
      "reasoning": "high"
    }
  },
  "limits": {
    "maxRepairAttempts": 2,
    "taskTimeoutMinutes": 30
  }
}
